					<script>
  document.addEventListener("DOMContentLoaded", () => {
    const otros = document.querySelectorAll(".ofcan .other");
    const intervalo = 2000; // cada 2 segundos

    function parpadearUnoAleatorio() {
      otros.forEach(el => el.classList.remove("parpadeando"));

      const aleatorio = otros[Math.floor(Math.random() * otros.length)];
      aleatorio.classList.add("parpadeando");

      // eliminar clase tras 1s (duración del parpadeo)
      setTimeout(() => {
        aleatorio.classList.remove("parpadeando");
      }, 1000);
    }

    setInterval(parpadearUnoAleatorio, intervalo);
  });
</script>
				</div>
