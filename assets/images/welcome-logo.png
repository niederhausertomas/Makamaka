		<style id="wp-custom-css">
			/* Cursor por defecto: mano blanca */
body, span {
  cursor: url('https://makamaka.es/wp-content/uploads/2025/05/hand_small.d0e91f45d3f79533913c.png') 16 0, auto !Important;
}

/* Cursor negro para elementos interactivos */
a,
button,
input[type="submit"],
input[type="button"],
input[type="reset"],
select,
textarea,
label,
[role="button"],
.clickable {
  cursor: url('https://makamaka.es/wp-content/uploads/2025/05/hand_black.cdabe9e31e9c5ffd0303.png') 16 0, auto!Important;
}

/* Cursor "grab" personalizado */
.grab,
[draggable="true"] {
  cursor: url('https://makamaka.es/wp-content/uploads/2025/06/descarga-1.png') 16 0, grab!Important;
}

/* Cursor "grabbing" mientras se arrastra */
.grabbing,
.dragging {
  cursor: url('https://makamaka.es/wp-content/uploads/2025/06/descarga-1.png') 16 0, grabbing!Important;
}
/* Fuente: Baskerville SemiBold */
@font-face {
  font-family: 'baskerville';
  src: url('https://makamaka.es/wp-content/uploads/2025/05/Baskerville-SemiBold.0e9d78b5277a93a978d3.woff2') format('woff2');
  font-weight: 600;
  font-style: normal;
  font-display: swap;
}

/* Fuente: ITC Avant Garde Gothic Std Bold Condensed */
@font-face {
  font-family: 'ITCC';
  src: url('https://makamaka.es/wp-content/uploads/2025/05/itc-avant-garde-gothic-std-bold-condensed-5895705e8fe31.77397177e5e321e7cd3b.woff2') format('woff2');
  font-weight: bold;
  font-style: normal;
  font-display: swap;
}

/* Fuente: ITC Avant Garde Gothic Std Bold */
@font-face {
  font-family: 'ITC';
  src: url('https://makamaka.es/wp-content/uploads/2025/05/itc-avant-garde-gothic-std-bold-589572c7e9955.d5235f7687b5470f8656.woff2') format('woff2');
  font-weight: bold;
  font-style: normal;
  font-display: swap;
}
		</style>
