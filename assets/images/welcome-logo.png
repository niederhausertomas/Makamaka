<script>
document.addEventListener("DOMContentLoaded", () => {
  // Solo activar si el usuario ha autorizado
  if (localStorage.getItem("audioHoverAllowed") !== "true") return;

  // Mapeo de clases a rutas de audio
  const audioMap = {
    "audio-hover-1": "/wp-content/uploads/audio1.mp3",
    "audio-hover-2": "/wp-content/uploads/audio2.mp3",
    "audio-hover-3": "/wp-content/uploads/audio3.mp3"
  };

  // Pre-cargar audios
  const audioPlayers = {};
  for (const className in audioMap) {
    const audio = new Audio(audioMap[className]);
    audio.preload = "auto";
    audioPlayers[className] = audio;
  }

  // Asociar eventos
  for (const className in audioMap) {
    const elements = document.querySelectorAll(`.${className}`);
    elements.forEach(el => {
      el.addEventListener("mouseenter", () => {
        const audio = audioPlayers[className];
        if (!audio.paused) {
          audio.currentTime = 0;
        }
        audio.play().catch(err => {
          // Si no se puede reproducir (por política del navegador), ignorar
          console.warn("No se pudo reproducir el audio:", err);
        });
      });

      el.addEventListener("mouseleave", () => {
        const audio = audioPlayers[className];
        audio.pause();
        audio.currentTime = 0;
      });
    });
  }
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const container = document.querySelector(".elementor-element-7f98cd4") || document.querySelector(".elementor-element.elementor-element-6e6d74b");

  // Guarda el fondo original
  const originalBg = window.getComputedStyle(container).backgroundImage;

  document.querySelectorAll(".jwWTyM").forEach(span => {
    span.addEventListener("mouseenter", () => {
      const newBg = span.getAttribute("data-bg");
      container.style.backgroundImage = `url(${newBg})`;
      container.style.backgroundSize = "cover";
      container.style.backgroundPosition = "center";
    });

    span.addEventListener("mouseleave", () => {
      container.style.backgroundImage = originalBg;
    });
  });
});
</script>
<script>
	document.addEventListener("DOMContentLoaded", function () {
  const imagenHover = document.getElementById('imagenHover');
  const zonaLupa = document.getElementById('zonaLupa');

  zonaLupa.addEventListener('mousemove', (e) => {
    const rect = zonaLupa.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    imagenHover.style.clipPath = `circle(100px at ${x}px ${y}px)`;
  });

  zonaLupa.addEventListener('mouseleave', () => {
    imagenHover.style.clipPath = `circle(0px at 0 0)`;
  });
		  });
</script>
